# Open5GS PQC Configuration Template
# Based on the paper's experimental setup

# This file defines the PQC algorithm configurations for Open5GS
# Modify these values to test different algorithm combinations

# Algorithm selection (from Table I in the paper)
# Options: secp256r1, rsa2048, p256_bikel1, p384_bikel3, p521_frodo1344shake,
#          p256_falcon513, p384_mldsa66, sphincssha2129ssimple

# Default configuration: Conventional ECC
SIGNATURE_ALG="secp256r1"
KEM_ALG="secp256r1"

# TLS cipher suites (for oqs-provider)
# The oqs-provider automatically handles hybrid cipher suites
TLS_SIG_ALGS="oqs_signature_algorithms"
TLS_GROUPS="X25519Kyber768Draft00:P-256Kyber768Draft00"

# Open5GS SBI (Service Based Interface) TLS settings
SBI_TLS_ENABLED="true"
SBI_TLS_PORT="443"

# Certificate paths
CERT_DIR="/etc/open5gs/tls"
CA_CERT="$CERT_DIR/ca/ca_cert.pem"

# NF-specific certificate paths
NRF_TLS_CERT="$CERT_DIR/nrf/tls.crt"
NRF_TLS_KEY="$CERT_DIR/nrf/tls.key"

AMF_TLS_CERT="$CERT_DIR/amf/tls.crt"
AMF_TLS_KEY="$CERT_DIR/amf/tls.key"

UPF_TLS_CERT="$CERT_DIR/upf/tls.crt"
UPF_TLS_KEY="$CERT_DIR/upf/tls.key"

UDR_TLS_CERT="$CERT_DIR/udr/tls.crt"
UDR_TLS_KEY="$CERT_DIR/udr/tls.key"

UDM_TLS_CERT="$CERT_DIR/udm/tls.crt"
UDM_TLS_KEY="$CERT_DIR/udm/tls.key"

AUSF_TLS_CERT="$CERT_DIR/ausf/tls.crt"
AUSF_TLS_KEY="$CERT_DIR/ausf/tls.key"

NSSF_TLS_CERT="$CERT_DIR/nssf/tls.crt"
NSSF_TLS_KEY="$CERT_DIR/nssf/tls.key"

BSF_TLS_CERT="$CERT_DIR/bsf/tls.crt"
BSF_TLS_KEY="$CERT_DIR/bsf/tls.key"

PCF_TLS_CERT="$CERT_DIR/pcf/tls.crt"
PCF_TLS_KEY="$CERT_DIR/pcf/tls.key"

SMF_TLS_CERT="$CERT_DIR/smf/tls.crt"
SMF_TLS_KEY="$CERT_DIR/smf/tls.key"
